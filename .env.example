# Copy to .env and fill in. Every AgentMem setting can be overridden with an
# AGENTMEM_* environment variable (see packages/agentmem/src/agentmem/config.py).

# Your Anthropic key. AgentMem is BYOK: the memory agent calls the LLM with
# *your* key, so cost and data handling stay on your side.
ANTHROPIC_API_KEY=sk-ant-...

# Which model runs the memory agent. Haiku is the cheap default; bump to a
# Sonnet-class model for eval-quality reminders. Check current IDs at
# https://docs.claude.com/en/docs/about-claude/models
AGENTMEM_MODEL=claude-haiku-4-5

# Where memory lives. Default is a JSON file under .agentmem/ in the project.
# AGENTMEM_STORE=sqlite:///.agentmem/run.db

# Fire a memory-step every N action turns (plus always on the first step).
# AGENTMEM_TRIGGER_EVERY_N=3
